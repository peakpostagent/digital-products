{
  "manifest_version": 3,
  "name": "DotEnv Preview",
  "version": "1.0.0",
  "description": "Syntax-highlight .env files on GitHub with grouping, sensitive value detection, and copy buttons.",
  "permissions": ["storage", "activeTab", "tabs"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://github.com/*/*/blob/*",
        "*://raw.githubusercontent.com/*",
        "*://gitlab.com/*/*/blob/*",
        "*://bitbucket.org/*/*/src/*"
      ],
      "js": ["lib/parser.js", "content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
