{
  "manifest_version": 3,
  "name": "Z-Index Inspector",
  "version": "1.0.0",
  "description": "Visualize z-index values and stacking contexts. Find conflicts, see the layer hierarchy, and debug overlaps.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
