{
  "manifest_version": 3,
  "name": "Review Clock",
  "version": "1.0.0",
  "description": "Track how long you spend reviewing GitHub pull requests. See cumulative weekly stats and effort estimates.",
  "permissions": ["storage", "alarms", "tabs"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://github.com/*/*/pull/*"
      ],
      "js": ["lib/tracker.js", "content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
