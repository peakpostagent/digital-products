{
  "manifest_version": 3,
  "name": "Meeting Cost Calculator",
  "version": "1.2.0",
  "description": "See the real cost of every meeting. Free live cost tracking plus optional Pro AI insights, CSV export, and 12-week trends.",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://extensionpay.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://calendar.google.com/*"
      ],
      "js": ["lib/calculator.js", "content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
