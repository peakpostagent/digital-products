# Environment variables for mcc-insights backend.
# Copy to .env.local and fill in real values for `vercel dev`.

# OpenAI (for insight generation)
OPENAI_API_KEY=

# Resend (for email delivery)
RESEND_API_KEY=
RESEND_FROM=MCC Pro <noreply@your-domain.com>

# Cron bearer token (generate with: openssl rand -hex 32)
CRON_SECRET=

# HMAC secret for unsubscribe tokens (generate with: openssl rand -hex 32)
UNSUBSCRIBE_SECRET=

# Public URL of the deployed backend (for unsubscribe links)
PUBLIC_BASE_URL=https://mcc-insights.vercel.app

# Vercel KV (auto-injected by Vercel integration, include locally for vercel dev)
KV_REST_API_URL=
KV_REST_API_TOKEN=
