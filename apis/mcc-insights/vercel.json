{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/register", "dest": "/api/register.js" },
    { "src": "/api/unsubscribe", "dest": "/api/unsubscribe.js" },
    { "src": "/api/benchmark", "dest": "/api/benchmark.js" },
    { "src": "/api/cron/weekly-digest", "dest": "/api/cron/weekly-digest.js" }
  ],
  "crons": [
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 9 * * 1"
    }
  ]
}
