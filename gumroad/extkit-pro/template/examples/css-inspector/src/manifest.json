{
  "manifest_version": 3,
  "name": "CSS Inspector — Example (ExtKit Pro)",
  "version": "1.0.0",
  "description": "Example extension shipped with ExtKit Pro — CSS custom-property inspector demonstrating the free-vs-Pro pattern with a content-script scan.",
  "permissions": ["storage", "activeTab", "scripting", "alarms"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/scan.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
